# Copy this file to .env and fill in your real values.
# .env is git-ignored and must NEVER be committed.

# ── LLM Provider ────────────────────────────────────────────────────────────
# Primary: OpenAI (GPT-4o-mini is recommended — good quality, low cost)
OPENAI_API_KEY=sk-...

# Fallback: Groq (fast, cheap, OpenAI-compatible API)
# GROQ_API_KEY=gsk_...

# ── LLM Configuration ───────────────────────────────────────────────────────
# Which provider to use: "openai" or "groq"
LLM_PROVIDER=openai

# Model name for the chosen provider
# OpenAI options : gpt-4o-mini, gpt-4o
# Groq options   : llama-3.1-8b-instant, llama-3.1-70b-versatile
LLM_MODEL=gpt-4o-mini

# ── Embeddings ───────────────────────────────────────────────────────────────
# Embedding model (OpenAI). Change if using a HuggingFace model locally.
EMBEDDING_MODEL=text-embedding-3-small

# ── Vector Store ─────────────────────────────────────────────────────────────
# Local directory where ChromaDB persists the index.
# Rebuild with: python src/build_index.py
CHROMA_PERSIST_DIR=./vector_index

# ── RAG Settings ─────────────────────────────────────────────────────────────
# Number of chunks to retrieve per query
RETRIEVAL_TOP_K=4

# Max conversation turns kept in context window (FR-06)
MAX_HISTORY_TURNS=5

# ── Logging (FR-07) ──────────────────────────────────────────────────────────
CONVERSATION_LOG_PATH=./logs/conversations.csv
