# Copy this file to .env and fill in your real values.
# .env is git-ignored and must NEVER be committed.

# Groq LLM configuration
GROQ_API_KEY=gsk_...
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant

# Retrieval embeddings
# llama-3.1-8b-instant is not an embedding model, so retrieval uses a local
# sentence-transformers model.
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Local directory where ChromaDB persists the index.
# Rebuild with: python src/build_index.py
CHROMA_PERSIST_DIR=./vector_index

# Number of chunks to retrieve per query
RETRIEVAL_TOP_K=4

# Minimum cosine-similarity score (0–1) for a retrieval hit to be included in
# the LLM context. Hits below this are still logged in sources for auditability
# but are excluded from the context block so the LLM cannot hallucinate from
# weak matches. Raise to 0.4+ for stricter grounding; lower to 0.1 if you
# want more permissive recall.
RETRIEVAL_MIN_SCORE=0.25

# Max conversation turns kept in context window (FR-06)
MAX_HISTORY_TURNS=5

# Conversation logging
CONVERSATION_LOG_PATH=./logs/conversations.csv
